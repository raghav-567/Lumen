# ── Backend environment (example) ─────────────────────
# Copy to backend/.env and fill in real values. NEVER commit the real .env.

# ── App ──
APP_NAME=KnowledgeDrift
DEBUG=true

# ── Auth (REQUIRED) ──
# SECRET_KEY signs JWTs. Generate a real value: `openssl rand -hex 32`
# The app refuses to start with this placeholder when DEBUG=false.
SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ── CORS ──
# Comma-separated list of allowed browser origins for the frontend.
FRONTEND_ORIGIN=http://localhost:3000

# ── Database / Redis / Celery ──
# (docker-compose overrides the host parts with service names for in-cluster networking)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledgedrift
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://postgres:postgres@localhost:5432/knowledgedrift

# ── LLM API keys (optional — leave blank to disable those features) ──
GEMINI_API_KEY=
GROQ_API_KEY=

# ── ChromaDB telemetry (keep disabled) ──
ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY=False

# ── ChromaDB server ──
# Set CHROMA_HOST to use the shared ChromaDB *server* (required when more than
# one process — API + Celery — accesses the store; docker-compose sets this to
# "chroma"). Leave blank to use an embedded PersistentClient (single-process
# local runs / tests) at CHROMA_PERSIST_DIR.
CHROMA_HOST=
CHROMA_PORT=8000
